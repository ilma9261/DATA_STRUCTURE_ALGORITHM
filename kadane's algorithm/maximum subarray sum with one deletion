//leetcode 1186

class Solution {
public:
    int maximumSum(vector<int>& a) {
        int n = a.size();
        
        int noDeletion = a[0];     
        int oneDeletion = 0;      
        int ans = a[0];

        for(int i = 1; i < n; i++) {
            oneDeletion = max(noDeletion, oneDeletion + a[i]);
            noDeletion = max(a[i], noDeletion + a[i]);
            ans = max(ans, max(noDeletion, oneDeletion));
        }

        return ans;
    }
};
