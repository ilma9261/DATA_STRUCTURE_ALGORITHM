//leetcode 152

class Solution {
public:
    int maxProduct(vector<int>& a) {
        int n=a.size();
       int maxending=a[0];
       int minending=a[0];
       int ans=a[0];
        for(int i=1;i<n;i++){
            int v1=a[i];
            int v2=maxending*a[i];
            int v3=minending*a[i];
            maxending=max(v1,max(v2,v3));
            minending=min(v1,min(v2,v3));
            ans=max(ans,max(maxending,minending));
        }
        return ans;
    }
};
