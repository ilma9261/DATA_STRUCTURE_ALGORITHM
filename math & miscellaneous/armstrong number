//check if a three digit number is armstrong or not

class Solution {
  public:
    bool armstrongNumber(int n) {
        // code here
        int ans=0;
        int num=n;
        while(n!=0){
            int digit=n%10;
            ans=ans+digit*digit*digit;
            n=n/10;
        }
        if(ans==num){
            return true;
        }
        else{
            return false;
        }
    }
};
