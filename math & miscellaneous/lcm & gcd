class Solution {
  public:
    vector<int> lcmAndGcd(int a, int b) {
        // code here
        int x=a;
        int y=b;
        vector<int> arr;
        while(b!=0){
            int temp=b;
            b=a%b;
            a=temp;
        }
        int gcd=a;
        int lcm=(x*y)/a;
        arr.push_back(lcm);
        arr.push_back(gcd);
        return arr;
    }
};
