class Solution {
  public:
    string removeChars(string str1, string str2) {
        // code here
        string res="";
        map<char,int> mp;
        for(int i=0;i<str2.size();i++){
            mp[str2[i]]++;
        }
        for(int i=0;i<str1.size();i++){
            if(mp[str1[i]]==0){
                res+=str1[i];
        }
        }
        return res;
    }
};
