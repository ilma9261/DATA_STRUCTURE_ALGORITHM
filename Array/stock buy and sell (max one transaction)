class Solution {
  public:
    int maxProfit(vector<int> &prices) {
        // code here
        int n=prices.size();
        int ans=0;
        int min_element=prices[0];
        for(int i=0;i<n;i++){
            min_element=min(min_element,prices[i]);
            int profit=prices[i]-min_element;
            ans=max(ans,profit);
        }
        return ans;
    }
};
