class Solution {
  public:
    string equilibrium(vector<int> &arr) {
        // code here
        int n=arr.size();
        vector<int> pre(n,0),suff(n,0);
        for(int i=1;i<n;i++){
            pre[i]=pre[i-1]+arr[i-1];
        }
        for(int i=n-2;i>=0;i--){
            suff[i]=suff[i+1]+arr[i+1];
        }
        for(int i=0;i<n;i++){
        if(pre[i]==suff[i]){
            return "true";
        }
        }
            return "false";
    }
};
