//leetcode 724
//same as equal sum of gfg nut using more optimal solution here

class Solution {
public:
    int pivotIndex(vector<int>& a) {
        int n=a.size();
        int sum=0;
        for(int i=0;i<n;i++){
            sum+=a[i];
        }
        int left=0;
        for (int i=0;i<n;i++){
           int right=sum-left-a[i];       //sum = left + a[i] + right
            if(left==right){
                return i;
            }
            left+=a[i];
        }
        return-1;
    }
};
