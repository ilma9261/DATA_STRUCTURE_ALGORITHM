//leetcode 560
//we use sliding window for find the number of subarrays that have a sum less than k

class Solution {
public:
    int subarraySum(vector<int>& a, int k) {
        int sum=0;
        int n=a.size();
        int res=0;
        unordered_map<int,int> f;
        f[0]=1;                          //empty subrarray
        for(int i=0;i<n;i++){
            sum+=a[i];
            int ques=sum-k;             //if a previous prefix sum is sum-k, then the subarray between that position and the current position will have sum k.
            res+=f[ques];
            f[sum]++;
        }
        return res;
    }
};
